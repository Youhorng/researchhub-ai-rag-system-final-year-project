# ResearchHub — EC2 Environment Template
# =========================================
# Copy this to .env on your EC2 instance:
#   cp .env.ec2.example .env
#
# This only contains vars needed for the EC2 stack (compose.ec2.yml).
# All heavy services (OpenSearch, Ollama, MinIO, Langfuse) are excluded.

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_live_
CLERK_PUBLISHABLE_KEY=pk_live_
CLERK_SECRET_KEY=sk_live_
CLERK_JWKS_URL=https://<your_clerk_frontend_api>/.well-known/jwks.json

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=rag_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=<strong_password_here>
# This is auto-constructed in compose.ec2.yml — do not change the host
POSTGRES_DATABASE_URL=postgresql+psycopg2://rag_user:<strong_password_here>@postgres:5432/rag_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS__HOST=redis
REDIS__PORT=6379
REDIS__PASSWORD=<redis_password_here>
REDIS__DB=0
REDIS__TTL_HOURS=6

# ── Disabled services (required by config.py but not running) ─────────────────
# These prevent startup errors — FastAPI loads settings eagerly
OPENAI_API_KEY=disabled
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=disabled
MINIO_SECRET_KEY=disabled
MINIO_BUCKET=researchhub-documents
LANGFUSE__ENABLED=false
LANGFUSE__PUBLIC_KEY=disabled
LANGFUSE__SECRET_KEY=disabled
